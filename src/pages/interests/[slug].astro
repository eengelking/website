---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { hero } from '../../data/hero';

export async function getStaticPaths() {
  const entries = await getCollection('interests', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const entryUrl = new URL(`/interests/${entry.id}`, Astro.site);
const ogImageUrl = new URL('/og-image.png', Astro.site);
const isoDate = entry.data.date.toISOString();

const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: isoDate,
  dateModified: isoDate,
  url: entryUrl,
  mainEntityOfPage: entryUrl,
  image: ogImageUrl,
  keywords: entry.data.tags.join(', '),
  author: {
    '@type': 'Person',
    name: hero.name,
    url: 'https://edengelking.com',
  },
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  jsonLd={[blogPostingLd]}
  ogType="article"
  publishedTime={isoDate}
>
  <article class="post">
    <div class="container">
      <a class="mono back-link" href="/interests">← Interests</a>
      <p class="post-date mono">{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</p>
      <h1>{entry.data.title}</h1>
      <div class="post-body">
        <Content />
      </div>
      <div class="post-tags">
        {entry.data.tags.map((tag) => <a class="mono" href={`/interests?q=${encodeURIComponent(tag)}`}>{tag}</a>)}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: var(--space-6) 0;
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .post-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: var(--space-3) 0 var(--space-1);
  }

  .post-body {
    max-width: 65ch;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-3);
  }

  .post-tags {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-5);
  }

  .post-tags a {
    font-size: var(--text-xs);
    color: var(--color-signal);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2px 8px;
  }

  .post-tags a:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
  }
</style>
