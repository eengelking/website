---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PostList } from '../../components/posts/PostList';
import { blogIntro } from '../../data/pageIntros';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const items = posts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  description: post.data.description,
  dateLabel: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' }),
  tags: post.data.tags,
  href: `/blog/${post.id}`,
}));
---

<BaseLayout title="Blog" description="Notes on infrastructure, architecture, and building things that hold up.">
  <section class="blog-header">
    <div class="container">
      <p class="eyebrow">blog</p>
      <h1>Notes from the field</h1>
      <p class="page-intro">{blogIntro}</p>
    </div>
  </section>

  <section class="blog-list">
    <div class="container">
      <PostList
        client:load
        items={items}
        emptyLabel="No posts yet — check back soon."
        searchPlaceholder={'Type to search posts — try "kubectl" or "meta"'}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .blog-header {
    padding: var(--space-6) 0 var(--space-4);
  }

  .page-intro {
    max-width: 55ch;
    color: var(--color-text-muted);
    margin-top: var(--space-2);
  }
</style>
