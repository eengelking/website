---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { hero } from '../../data/hero';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(`/blog/${post.id}`, Astro.site);
const ogImageUrl = new URL('/og-image.png', Astro.site);
const isoDate = post.data.date.toISOString();

const blogPostingLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: isoDate,
  dateModified: isoDate,
  url: postUrl,
  mainEntityOfPage: postUrl,
  image: ogImageUrl,
  keywords: post.data.tags.join(', '),
  author: {
    '@type': 'Person',
    name: hero.name,
    url: 'https://edengelking.com',
  },
  publisher: {
    '@type': 'Person',
    name: hero.name,
    url: 'https://edengelking.com',
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  jsonLd={[blogPostingLd]}
  ogType="article"
  publishedTime={isoDate}
>
  <article class="post">
    <div class="container">
      <a class="mono back-link" href="/blog">← Blog</a>
      <p class="post-date mono">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</p>
      <h1>{post.data.title}</h1>
      <div class="post-body">
        <Content />
      </div>
      <div class="post-tags">
        {post.data.tags.map((tag) => <a class="mono" href={`/blog?q=${encodeURIComponent(tag)}`}>{tag}</a>)}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: var(--space-6) 0;
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .post-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin: var(--space-3) 0 var(--space-1);
  }

  .post-body {
    max-width: 65ch;
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-top: var(--space-4);
  }

  .post-body :global(p) {
    margin-bottom: var(--space-3);
  }

  .post-body :global(code) {
    font-family: var(--font-mono);
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-radius: var(--radius);
    padding: 0.15em 0.4em;
    font-size: 0.9em;
  }

  .post-tags {
    display: flex;
    gap: var(--space-1);
    margin-top: var(--space-5);
  }

  .post-tags a {
    font-size: var(--text-xs);
    color: var(--color-signal);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2px 8px;
  }

  .post-tags a:hover {
    border-color: var(--color-accent-dim);
    color: var(--color-accent);
  }
</style>
