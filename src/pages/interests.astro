---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('interests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Interests" description="A few things Ed Engelking spends time on outside of work." noindex>
  <section class="interests-header">
    <div class="container">
      <p class="eyebrow">interests</p>
      <h1>Outside of work</h1>
    </div>
  </section>

  <section class="interests-list">
    <div class="container">
      {entries.map((entry) => (
        <article class="interest-entry">
          <h2>{entry.data.title}</h2>
          <p class="entry-date mono">{entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</p>
          <p>{entry.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .interests-header {
    padding: var(--space-6) 0 var(--space-4);
  }

  .interest-entry {
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  .entry-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
</style>
