---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PostList } from '../components/posts/PostList';
import { interestsIntro, opinionsDisclaimer } from '../data/pageIntros';

const entries = (await getCollection('interests', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const items = entries.map((entry) => ({
  slug: entry.id,
  title: entry.data.title,
  description: entry.data.description,
  dateLabel: entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', timeZone: 'UTC' }),
  tags: entry.data.tags,
  href: `/interests/${entry.id}`,
}));

const interestsListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: entries.map((entry, i) => ({
    '@type': 'CreativeWork',
    position: i + 1,
    name: entry.data.title,
    description: entry.data.description,
    dateCreated: entry.data.date.toISOString(),
    keywords: entry.data.tags.join(', '),
    url: new URL(`/interests/${entry.id}`, Astro.site),
  })),
};
---

<BaseLayout
  title="Interests"
  description="A few things Ed Engelking spends time on outside of work."
  jsonLd={[interestsListLd]}
>
  <section class="interests-header">
    <div class="container">
      <p class="eyebrow">interests</p>
      <h1>Outside of work</h1>
      <p class="page-intro">{interestsIntro}</p>
      <p class="disclaimer mono">{opinionsDisclaimer}</p>
    </div>
  </section>

  <section class="interests-list">
    <div class="container">
      <PostList
        client:load
        items={items}
        emptyLabel="Nothing here yet — check back soon."
        searchPlaceholder={'Type to search — try "germany" or "personal"'}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .interests-header {
    padding: var(--space-6) 0 var(--space-4);
  }

  .page-intro {
    max-width: 75ch;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-top: var(--space-2);
  }

  .disclaimer {
    max-width: 75ch;
    color: var(--color-text-muted);
    opacity: 0.7;
    font-size: var(--text-xs);
    margin-top: var(--space-2);
  }
</style>
