---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/hero/Hero.astro';
import About from '../components/about/About.astro';
import ProjectGrid from '../components/projects/ProjectGrid.astro';
import ContactCTA from '../components/contact/ContactCTA.astro';
import { Timeline } from '../components/timeline/Timeline';
import { StatStrip } from '../components/achievements/StatStrip';
---

<BaseLayout title="Home">
  <Hero />

  <section class="stats-section">
    <div class="container">
      <StatStrip client:visible />
    </div>
  </section>

  <About />

  <section class="timeline-section">
    <div class="container">
      <p class="eyebrow">career — uptime log</p>
      <h2>30 years, 12 roles, one pattern</h2>
      <Timeline client:visible />
    </div>
  </section>

  <ProjectGrid />
  <ContactCTA />
</BaseLayout>

<style>
  .stats-section {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-5) 0;
  }
</style>
