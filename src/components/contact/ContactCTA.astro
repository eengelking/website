---
import { contact } from '../../data/contact';
---

<section class="contact">
  <div class="container contact-inner">
    <div>
      <p class="eyebrow">get in touch</p>
      <h2>Let's talk about the hardest problem on your roadmap.</h2>
    </div>
    <a class="mono contact-link" href={contact.linkedinUrl} target="_blank" rel="noopener noreferrer">
      {contact.ctaLabel} →
    </a>
  </div>
</section>

<style>
  .contact-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }

  h2 {
    max-width: 30ch;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius);
    font-size: var(--text-sm);
    white-space: nowrap;
  }

  .contact-link:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }
</style>
