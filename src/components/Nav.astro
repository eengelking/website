---
import { contact } from '../data/contact';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Skills', href: '/skills' },
  { label: 'Blog', href: '/blog' },
];
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand mono" href="/">
      <span class="prompt-symbol" aria-hidden="true">$</span>
      <span class="typed-text">Ed Engelking</span><span class="brand-cursor" aria-hidden="true">_</span>
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
    <nav id="site-nav">
      <ul>
        {navItems.filter((item) => !item.hidden).map((item) => {
          const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
          return (
            <li>
              <a href={item.href} class={isActive ? 'active' : ''}>{item.label}</a>
            </li>
          );
        })}
        <li>
          <a href={contact.linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
        </li>
        <li>
          <a href={contact.githubUrl} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
        </li>
        <li>
          <a href={contact.youtubeUrl} target="_blank" rel="noopener noreferrer">YouTube ↗</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    font-size: var(--text-base);
    color: var(--color-text);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .prompt-symbol {
    color: var(--color-tag);
    font-weight: 700;
    margin-right: 0.4em;
  }

  .typed-text {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 12ch;
    animation: brand-typing 1.1s steps(12, end);
  }

  .brand-cursor {
    color: var(--color-accent);
    animation: brand-blink 1s step-end infinite;
    animation-delay: 1.1s;
  }

  @keyframes brand-typing {
    from {
      width: 0;
    }
  }

  @keyframes brand-blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typed-text {
      animation: none;
      width: auto;
    }

    .brand-cursor {
      animation: none;
    }
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    padding: var(--space-1) 0;
    border-bottom: 1px solid transparent;
  }

  nav a:hover {
    color: var(--color-text);
  }

  nav a.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-1);
  }

  .nav-toggle span {
    width: 22px;
    height: 2px;
    background: var(--color-text);
    display: block;
  }

  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
    }

    nav {
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
      display: none;
    }

    nav.open {
      display: block;
    }

    nav ul {
      flex-direction: column;
      gap: 0;
      padding: var(--space-2) var(--space-3);
    }

    nav li {
      border-bottom: 1px solid var(--color-border);
    }

    nav a {
      display: block;
      padding: var(--space-2) 0;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });
</script>
